generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users (Bailleurs / Propriétaires) ───
model User {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  firstName     String    @default("")
  lastName      String    @default("")
  phone         String?
  // Full address required for quittances
  addressLine1  String    @default("")
  addressLine2  String?
  city          String    @default("")
  postalCode    String    @default("")
  country       String    @default("France")
  // Stripe
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Better Auth relations
  sessions      Session[]
  accounts      Account[]

  // Business relations
  properties    Property[]
  tenants       Tenant[]
  leases        Lease[]
  transactions  Transaction[]
  documents     Document[]
  bankConnections BankConnection[]
  expenses      Expense[]
  organizationMembers OrganizationMember[]
  reminders     Reminder[]
  notifications Notification[]
  auditLogs    AuditLog[]
}

// ─── Better Auth: Sessions ───
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── Better Auth: Accounts (credential / OAuth providers) ───
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

// ─── Better Auth: Email Verification Tokens ───
model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// ─── Properties (Biens Immobiliers) ───
model Property {
  id            String   @id @default(cuid())
  userId        String
  name          String   // "Appartement Rue de Rivoli"
  type          PropertyType
  addressLine1  String
  addressLine2  String?
  city          String
  postalCode    String
  country       String   @default("France")
  surface       Float?   // m²
  rooms         Int?
  description   String?
  // Tax reference
  cadastralRef  String?  // Référence cadastrale
  taxRef        String?  // Numéro fiscal du bien
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases        Lease[]
  maintenanceTickets MaintenanceTicket[]
  expenses      Expense[]
  units         Unit[]
  reminders     Reminder[]
  notifications Notification[]

  @@index([userId])
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  COMMERCIAL
  PARKING
  OTHER
}

// ─── Tenants (Locataires) ───
model Tenant {
  id            String   @id @default(cuid())
  userId        String   // Owner who manages this tenant
  firstName     String
  lastName      String
  email         String?
  phone         String?
  addressLine1  String   // Current address (or same as property)
  addressLine2  String?
  city          String
  postalCode    String
  country       String   @default("France")
  dateOfBirth   DateTime?
  placeOfBirth  String?
  // Emergency contact
  emergencyName  String?
  emergencyPhone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases        Lease[]
  accessTokens  TenantAccessToken[]
  maintenanceTickets MaintenanceTicket[]
  reminders     Reminder[]
  notifications Notification[]

  @@index([userId])
}

// ─── Tenant Portal Access Tokens (Magic Links) ───
model TenantAccessToken {
  id        String    @id @default(cuid())
  tenantId  String
  token     String    @unique
  expiresAt DateTime?
  lastUsedAt DateTime?
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId])
}

// ─── Leases (Baux) ───
model Lease {
  id              String    @id @default(cuid())
  userId          String
  propertyId      String
  tenantId        String
  unitId          String?
  // Financial
  rentAmount      Float     // Loyer hors charges (€)
  chargesAmount   Float     // Provision pour charges (€)
  depositAmount   Float     // Dépôt de garantie (€)
  // Dates
  startDate       DateTime
  endDate         DateTime?
  // IRL revision
  irlReferenceValue Float?  // IRL at signature
  irlReferenceQuarter String? // e.g. "T4-2025"
  revisionDate    DateTime? // Date anniversaire de révision
  // Payment
  paymentDay      Int       @default(1) // Day of month rent is due
  paymentMethod   PaymentMethod @default(TRANSFER)
  // Lease type
  leaseType       LeaseType @default(UNFURNISHED)
  status          LeaseStatus @default(ACTIVE)
  // Document reference
  documentUrl     String?   // Uploaded lease PDF
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit            Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  guarantor       Guarantor?
  transactions    Transaction[]

  @@index([userId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([unitId])
}

enum PaymentMethod {
  TRANSFER
  CHECK
  CASH
  DIRECT_DEBIT
  OTHER
}

enum LeaseType {
  UNFURNISHED   // Location vide
  FURNISHED     // Location meublée
  COMMERCIAL    // Bail commercial
  SEASONAL      // Location saisonnière
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  TERMINATED
  EXPIRED
}

// ─── Transactions (Paiements de Loyers) ───
model Transaction {
  id              String    @id @default(cuid())
  userId          String
  leaseId         String
  // Financial
  amount          Float     // Total amount received
  rentPortion     Float     // Part loyer
  chargesPortion  Float     // Part charges
  // Period
  periodStart     DateTime  // Start of rental period
  periodEnd       DateTime  // End of rental period
  // Payment info
  paidAt          DateTime?
  dueDate         DateTime
  paymentMethod   PaymentMethod?
  // Status
  status          TransactionStatus @default(PENDING)
  isFullPayment   Boolean   @default(false)
  // Generated document
  receiptType     ReceiptType?      // QUITTANCE or RECU
  receiptUrl      String?           // Generated PDF URL
  receiptNumber   String?           // Sequential number
  // Banking reconciliation (Open Banking prep)
  bankTransactionId String?  @unique // External bank transaction ID
  bankMatchedAt   DateTime?
  bankRawData     Json?     // Raw transaction data from bank API
  // Metadata
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lease           Lease     @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leaseId])
  @@index([status])
  @@index([dueDate])
  @@index([bankTransactionId])
}

enum TransactionStatus {
  PENDING
  PARTIAL
  PAID
  LATE
  CANCELLED
}

enum ReceiptType {
  QUITTANCE   // Full payment receipt (legally binding)
  RECU        // Partial payment receipt
}

// ─── Documents (AI-extracted & generated) ───
model Document {
  id            String       @id @default(cuid())
  userId        String
  type          DocumentType
  fileName      String
  fileUrl       String
  mimeType      String
  fileSize      Int          // bytes
  // AI extraction
  extractedData Json?        // Structured data extracted by LLM
  extractionStatus ExtractionStatus @default(PENDING)
  extractionError  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

enum DocumentType {
  LEASE_SCAN        // Uploaded lease for OCR
  QUITTANCE_PDF     // Generated rent receipt
  RECU_PDF          // Generated partial receipt
  OTHER
}

enum ExtractionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Bank Connections (Open Banking / DSP2 prep) ───
model BankConnection {
  id              String   @id @default(cuid())
  userId          String
  provider        String   // "bridge" | "powens"
  providerUserId  String?  // User ID on provider side
  providerItemId  String?  // Item/connection ID on provider
  bankName        String?
  status          BankConnectionStatus @default(PENDING)
  lastSyncAt      DateTime?
  consentExpiresAt DateTime?
  accessToken     String?  // Encrypted
  refreshToken    String?  // Encrypted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEvents   BankWebhookEvent[]

  @@index([userId])
  @@unique([provider, providerItemId])
}

enum BankConnectionStatus {
  PENDING
  ACTIVE
  EXPIRED
  ERROR
  REVOKED
}

// ─── Bank Webhook Events (DSP2 event log) ───
model BankWebhookEvent {
  id              String   @id @default(cuid())
  connectionId    String?
  provider        String
  eventType       String   // "transaction.created", "item.refreshed", etc.
  payload         Json     // Raw webhook payload
  processedAt     DateTime?
  error           String?
  createdAt       DateTime @default(now())

  connection      BankConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([connectionId])
  @@index([eventType])
  @@index([createdAt])
}

// Stripe webhook events for idempotency — prevents duplicate processing on retries
model StripeWebhookEvent {
  id           String   @id @default(cuid())
  stripeEventId String  @unique  // Stripe's event ID — used for idempotency check
  eventType    String
  processedAt  DateTime @default(now())

  @@index([eventType])
  @@index([processedAt])
}

// ─── IRL Reference Data (INSEE indices) ───
model IrlIndex {
  id        String   @id @default(cuid())
  quarter   String   @unique // e.g. "T4-2025"
  year      Int
  trimester Int      // 1-4
  value     Float    // e.g. 145.78
  publishedAt DateTime?
  createdAt DateTime @default(now())

  @@index([year, trimester])
}

// ─── Maintenance Tickets (Demandes de réparation) ───
model MaintenanceTicket {
  id          String              @id @default(cuid())
  tenantId    String
  propertyId  String
  unitId      String?
  title       String
  description String
  status      MaintenanceStatus   @default(OPEN)
  priority    MaintenancePriority @default(MEDIUM)
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit        Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  attachments MaintenanceAttachment[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([unitId])
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model MaintenanceAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  fileName  String
  fileType  String   // MIME type
  fileUrl   String
  fileSize  Int      // bytes
  createdAt DateTime @default(now())

  ticket    MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─── Expenses (Dépenses / Charges propriétaire) ───
model Expense {
  id          String          @id @default(cuid())
  userId      String
  propertyId  String?
  vendorName  String
  description String?
  amount      Float
  category    ExpenseCategory
  date        DateTime
  invoiceUrl  String?         // Uploaded invoice file
  aiExtracted Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property?       @relation(fields: [propertyId], references: [id])

  @@index([userId])
  @@index([propertyId])
  @@index([category])
}

enum ExpenseCategory {
  PLUMBING          // Plomberie
  ELECTRICAL        // Électricité
  GENERAL_MAINTENANCE // Entretien général
  INSURANCE         // Assurance
  TAX               // Taxes / Impôts
  CONDO_FEES        // Charges de copropriété
  MANAGEMENT_FEES   // Frais de gestion
  RENOVATION        // Rénovation / Travaux
  OTHER             // Autre
}

// ─── Organization / Workspace ─────────────────────────────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

// ─── Unit (multi-unit building support) ───────────────────────────────────────

enum UnitStatus {
  VACANT
  RENTED
  DRAFT
}

// ─── Guarantor ────────────────────────────────────────────────────────────────

enum GuarantorType {
  PERSON
  COMPANY
}

enum GuarantorStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Reminders ───────────────────────────────────────────────────────────────

enum ReminderType {
  RENT_DUE
  LEASE_RENEWAL
  DEPOSIT_RETURN
  TAX_DEADLINE
  CONDO_FEE
  MAINTENANCE_DUE
  CUSTOM
}

enum ReminderStatus {
  PENDING
  COMPLETED
  SNOOZED
  CANCELLED
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  RENT_REMINDER
  PAYMENT_CONFIRMED
  PAYMENT_LATE
  MAINTENANCE_UPDATE
  LEASE_EXPIRING
  DOCUMENT_READY
  MESSAGE
  SYSTEM
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ─── Organization (multi-user workspaces) ────────────────────────────────────

model Organization {
  id                   String              @id @default(cuid())
  name                 String
  slug                 String              @unique
  plan                 Plan                @default(FREE)
  stripeOrgId          String?             @unique
  subscriptionStatus   SubscriptionStatus   @default(TRIAL)
  trialEndsAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  members              OrganizationMember[]
}

model OrganizationMember {
  id              String    @id @default(cuid())
  organizationId  String
  userId          String
  role            OrgRole   @default(VIEWER)
  joinedAt        DateTime  @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ─── Unit (multi-unit building support) ──────────────────────────────────────

model Unit {
  id          String       @id @default(cuid())
  propertyId  String
  name       String
  floor      Int?
  unitNumber String?
  surface    Float?
  rooms      Int?
  type       PropertyType @default(APARTMENT)
  status     UnitStatus   @default(VACANT)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases            Lease[]
  maintenanceTickets MaintenanceTicket[]

  @@index([propertyId])
  @@index([status])
}

// ─── Guarantor (lease financial backing) ────────────────────────────────────

model Guarantor {
  id                 String           @id @default(cuid())
  leaseId            String           @unique
  type               GuarantorType
  firstName          String?
  lastName           String?
  dateOfBirth        DateTime?
  placeOfBirth       String?
  companyName        String?
  siren              String?
  email              String
  phone              String?
  addressLine1       String
  addressLine2       String?
  city               String
  postalCode         String
  country            String           @default("France")
  financialDocumentIds String[]
  status             GuarantorStatus  @default(PENDING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  lease              Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
}

// ─── Reminder (task/deadline tracking) ──────────────────────────────────────

model Reminder {
  id               String          @id @default(cuid())
  userId           String
  leaseId          String?
  propertyId       String?
  tenantId         String?
  type             ReminderType
  title            String
  description      String?
  dueDate          DateTime
  completedAt      DateTime?
  snoozedUntil     DateTime?
  isRecurring      Boolean         @default(false)
  recurringInterval Int?
  nextDueDate      DateTime?
  priority         ReminderPriority @default(MEDIUM)
  status           ReminderStatus  @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  property         Property?       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant           Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueDate])
  @@index([userId, type])
  @@index([leaseId])
  @@index([propertyId])
}

// ─── Notification (user-facing alerts) ──────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String
  tenantId    String?
  propertyId  String?
  type        NotificationType
  title       String
  body        String
  data        Json?
  read        Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property?        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([tenantId])
  @@index([propertyId])
}

// ─── Audit Log (security/compliance trail) ───────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  userId      String
  entityType  String
  entityId    String
  action      AuditAction
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}
